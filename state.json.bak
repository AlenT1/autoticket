            "snippet": "      className={`ch-item${s.id === activeSessionId ? ' ch-item--active' : ''}${stateClass}`}\n      onClick={() => onSelectSession(s.id)}\n      title={isStreaming ? 'Reply in progress…' : isCompleted ? 'New reply ready' : undefined}\n    >\n      {editingId === s.id ? (\n        <div className=\"ch-edit-row\">\n          <input\n            ref={editRef}\n            className=\"ch-edit-input\"\n            value={editTitle}\n            onChange={e => setEditTitle(e.target.value)}\n            onKeyDown={e => { if (e.key === 'Enter') confirmRename(); if (e.key === 'Escape') cancelRename(); }}\n          />\n          <button className=\"ch-edit-action\" onClick={confirmRename}><Check size={12} /></button>\n          <button className=\"ch-edit-action\" onClick={cancelRename}><X size={12} /></button>\n        </div>\n      ) : (\n        <>\n          {isStreaming ? (\n            <span className=\"ch-icon ch-icon--streaming\" aria-hidden>\n              <span className=\"ch-spinner\" />\n            </span>\n          ) : isCompleted ? (\n            <span className=\"ch-icon ch-icon--completed\" aria-hidden />\n          ) : (\n            icon || <MessageSquare size={14} className=\"ch-icon\" />\n          )}\n          <span className=\"ch-title\">{s.title}</span>\n          {showShareBadge && (s.share_count ?? 0) > 0 && (\n            <span className=\"ch-shared-badge\" title={`Shared with ${s.share_count} ${s.share_count === 1 ? 'person' : 'people'}`}>\n              <Users size={10} /> {s.share_count}\n            </span>\n          )}\n          <div className=\"ch-actions\">\n            <button className=\"ch-action\" onClick={(e) => handlePin(e, s.id)} title={s.is_pinned ? 'Unpin' : 'Pin'}>\n              <Pin size={12} />\n            </button>\n            <button className=\"ch-action\" onClick={(e) => startShare(e, s)} title=\"Share\">\n              <Share2 size={12} />\n            </button>\n            <button className=\"ch-action\" onClick={(e) => startRename(e, s)} title=\"Rename\">\n              <PenLine size={12} />\n            </button>\n            <button className=\"ch-action ch-action--archive\" onClick={(e) => handleArchive(e, s.id)} title=\"Archive\">\n              <Archive size={12} />\n            </button>\n            <button className=\"ch-action ch-action--delete\" onClick={(e) => handleDelete(e, s.id)} title=\"Delete\">\n              <Trash2 size={12} />\n            </button>\n          </div>\n        </>\n      )}\n    </div>",
