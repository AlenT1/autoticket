      "enriched": {
        "bug_id": "e8c18e053f51557b",
        "summary": "Central frontend sidebar has no <768px drawer mode or dismissable backdrop",
        "description_md": "### Symptom\nThe mobile sidebar behavior advertised for widths below 768 px is absent. The sidebar remains the fixed desktop panel, and there is no drawer/backdrop interaction for small screens.\n\n### Where\n- `apps/centralfrontend/src/components/Sidebar.tsx:1-260` — sidebar rendering logic only distinguishes collapsed vs expanded desktop navigation; no mobile drawer state or backdrop handling appears in this component.\n- `apps/centralfrontend/src/global.css:37-52` — `.sidebar` is fixed at 220 px wide with desktop layout rules.\n- `apps/centralfrontend/src/global.css:118-120` — `.sidebar-collapsed .main-content` only accounts for the 48 px collapsed desktop variant.\n- `apps/centralfrontend/src/global.css:3455-3458` and `apps/centralfrontend/src/components/ActivityFeed.tsx:154-156` — nearby drawer patterns in the codebase use a backdrop element with click-to-close behavior, but the sidebar does not follow that pattern.\n\n### Code snippet\n```tsx\nexport function Sidebar({ collapsed = false, onToggleCollapse, features = [] }: SidebarProps) {\n  const [providers, setProviders] = useState<ProviderInfo[]>([]);\n  const [providersOpen, setProvidersOpen] = useState(() => {\n    try {\n      const v = localStorage.getItem('central:sidebar:providersOpen');\n      return v === '1';\n    } catch {\n      return false;\n    }\n  });\n  useEffect(() => {\n    try { localStorage.setItem('central:sidebar:providersOpen', providersOpen ? '1' : '0'); } catch { /* ignore */ }\n  }, [providersOpen]);\n  const [navOpen, setNavOpen] = useState(true);\n  const [appsOpen, setAppsOpen] = useState(true);\n  const [adminOpen, setAdminOpen] = useState(true);\n  const [apps, setApps] = useState<AppInfo[]>([]);\n  const [appHealth, setAppHealth] = useState<Record<string, AppHealthInfo>>({});\n  const [activePopover, setActivePopover] = useState<string | null>(null);\n\n  const load = useCallback(() => {\n    fetchProviders().then(p => setProviders(p)).catch(() => {});\n    fetchApps().then(a => setApps(a)).catch(() => {});\n    fetchAppHealth().then(h => setAppHealth(h)).catch(() => {});\n  }, []);\n\n  useEffect(() => { load(); }, [load]);\n\n  useEffect(() => {\n    const onUpdate = () => { fetchProviders().then(p => setProviders(p)).catch(() => {}); };\n    window.addEventListener('providers-updated', onUpdate);\n    return () => window.removeEventListener('providers-updated', onUpdate);\n  }, []);\n\n  const connected = providers.filter(p => p.connected);\n\n  const handleConnect = (name: string) => {\n    if (TOKEN_PROVIDERS.has(name)) {\n      handleRefresh(name);\n    } else {\n      window.location.href = getProviderAuthUrl(name);\n    }\n  };\n```\n\n### Reproduction steps\n1. Open the central frontend in a viewport narrower than 768 px.\n2. Observe the sidebar presentation and navigation behavior.\n3. Attempt to dismiss the sidebar by interacting with the page background.\n4. Compare the result with the documented mobile drawer behavior.\n\n### Expected behavior\nAt widths below 768 px, the sidebar is presented as a drawer-style panel with a dismissable backdrop.\n\n### Actual behavior\nThe sidebar code and stylesheet only define the fixed desktop sidebar and the 48 px collapsed variant; no 768 px breakpoint, drawer styling, or backdrop dismissal handler is present.\n\n### Last toucher\nEvgeny Kagan on 2025-03-05\n\n### Related\n- `apps/centralfrontend/src/components/ActivityFeed.tsx` and `apps/centralfrontend/src/views/SkillsFlowsPage.tsx` show existing drawer/backdrop interaction patterns elsewhere in the frontend.\n- `apps/centralfrontend/src/global.css` contains the only sidebar layout rules and only desktop/collapsed sizing.\n",
        "reproduction_steps": [
          {
            "order": 1,
            "text": "Open the central frontend in a viewport narrower than 768 px."
          },
          {
            "order": 2,
            "text": "Observe the sidebar presentation and navigation behavior."
          },
          {
            "order": 3,
            "text": "Attempt to dismiss the sidebar by interacting with the page background."
          },
          {
            "order": 4,
            "text": "Compare the result with the documented mobile drawer behavior."
          }
        ],
        "expected_behavior": "At widths below 768 px, the sidebar is presented as a drawer-style panel with a dismissable backdrop.",
        "actual_behavior": "The sidebar remains the fixed desktop panel; the codebase has no 768 px breakpoint, drawer styling, or backdrop dismissal handler for the sidebar.",
        "code_references": [
          {
            "repo_alias": "_core",
            "repo_url": null,
            "file_path": "apps/centralfrontend/src/components/Sidebar.tsx",
            "line_start": 1,
            "line_end": 260,
            "commit_sha": "56e7935195ddd17cd1684743197fada538cdb98c",
            "snippet": "import { useState, useEffect, useCallback } from 'react';\nimport { Link } from 'react-router-dom';\nimport {\n  fetchProviders,\n  fetchApps,\n  getProviderAuthUrl,\n  disconnectProvider as apiDisconnect,\n  refreshProvider as apiRefresh,\n  fetchAppHealth,\n  invalidateProviderCache,\n  type ProviderInfo,\n  type AppHealthInfo,\n  type AppInfo,\n} from '../api';\n\nconst PROVIDER_ICONS: Record<string, string> = {\n  mail: '\\u{1F4E7}',\n  'message-square': '\\u{1F4AC}',\n  folder: '\\u{1F4C2}',\n  search: '\\u{1F50D}',\n};\n\nconst APP_ICON_MAP: Record<string, string> = {\n  scales: '\\u{2696}\\u{FE0F}',\n  chart: '\\u{1F4CA}',\n  calendar: '\\u{1F4C5}',\n  brain: '\\u{1F9E0}',\n  shield: '\\u{1F6E1}\\u{FE0F}',\n  bot: '\\u{1F916}',\n  clipboard: '\\u{1F4CB}',\n  folder: '\\u{1F4C2}',\n};\n\nconst TOKEN_PROVIDERS = new Set(['outlook', 'teams']);\n\ninterface SidebarProps {\n  collapsed?: boolean;\n  onToggleCollapse?: () => void;\n  features?: string[];\n}\n\nexport function Sidebar({ collapsed = false, onToggleCollapse, features = [] }: SidebarProps) {\n  const [providers, setProviders] = useState<ProviderInfo[]>([]);\n  const [providersOpen, setProvidersOpen] = useState(() => {\n    try {\n      const v = localStorage.getItem('central:sidebar:providersOpen');\n      return v === '1';\n    } catch {\n      return false;\n    }\n  });\n  useEffect(() => {\n    try { localStorage.setItem('central:sidebar:providersOpen', providersOpen ? '1' : '0'); } catch { /* ignore */ }\n  }, [providersOpen]);\n  const [navOpen, setNavOpen] = useState(true);\n  const [appsOpen, setAppsOpen] = useState(true);\n  const [adminOpen, setAdminOpen] = useState(true);\n  const [apps, setApps] = useState<AppInfo[]>([]);\n  const [appHealth, setAppHealth] = useState<Record<string, AppHealthInfo>>({});\n  const [activePopover, setActivePopover] = useState<string | null>(null);\n\n  const load = useCallback(() => {\n    fetchProviders().then(p => setProviders(p)).catch(() => {});\n    fetchApps().then(a => setApps(a)).catch(() => {});\n    fetchAppHealth().then(h => setAppHealth(h)).catch(() => {});\n  }, []);\n\n  useEffect(() => { load(); }, [load]);\n\n  useEffect(() => {\n    const onUpdate = () => { fetchProviders().then(p => setProviders(p)).catch(() => {}); };\n    window.addEventListener('providers-updated', onUpdate);\n    return () => window.removeEventListener('providers-updated', onUpdate);\n  }, []);\n\n  const connected = providers.filter(p => p.connected);\n\n  const handleConnect = (name: string) => {\n    if (TOKEN_PROVIDERS.has(name)) {\n      handleRefresh(name);\n    } else {\n      window.location.href = getProviderAuthUrl(name);\n    }\n  };",
            "blame_author": "Evgeny Kagan",
            "blame_date": "2025-03-05"
          },
