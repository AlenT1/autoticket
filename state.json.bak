            "snippet": ".app-shell {\n  display: flex;\n  height: 100%;\n}\n\n.sidebar {\n  position: fixed;\n  top: 48px;\n  left: 0;\n  bottom: 0;\n  width: 220px;\n  transition: width 0.15s ease;\n  background: var(--surface);\n  border-right: 1px solid var(--border-subtle);\n  display: flex;\n  flex-direction: column;\n  overflow-y: auto;\n  overflow-x: hidden;\n  z-index: 50;\n}\n\n.sidebar--collapsed {\n  width: 48px;\n  align-items: center;\n  padding-top: 4px;\n  gap: 2px;\n}\n\n.main-content {\n  margin-left: 220px;\n  margin-top: 48px;\n  width: calc(100vw - 220px);\n  height: calc(100vh - 48px);\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n  transition: margin-left 0.15s ease, width 0.15s ease;\n}\n\n.sidebar-collapsed .main-content {\n  margin-left: 48px;\n  width: calc(100vw - 48px);\n}\n\n.route-layer {\n  flex: 1;\n  min-height: 0;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n\n.route-layer--chat {\n  flex-direction: row;\n}",
            "blame_author": "Evgeny Kagan",
