            "commit_sha": null,
            "snippet": "    skipped = []\n\n    logger.info(\n        \"Smart dispatch: dispatching %s, skipping %s (counts: %s)\",\n        dispatched, skipped, categories_with_counts,\n    )\n\n    # --- Phase 1: Orchestrator announces ---\n    yield {\n        \"type\": \"orchestrator_start\",\n        \"agent_name\": \"Orchestration Manager\",\n        \"total_agents\": len(dispatched),\n        \"agents\": [\n            {\n                \"agent_id\": agent_ids[cat],\n                \"agent_name\": SME_DISPLAY_NAMES[cat],\n                \"category\": cat,\n                \"deviation_count\": (categories_with_counts or {}).get(cat, 0),\n            }\n            for cat in SME_CATEGORIES\n        ],\n        \"done\": False,\n    }\n\n    # Emit agent_skipped for categories with no deviations\n    for cat in skipped:\n        yield {\n            \"type\": \"agent_skipped\",\n            \"agent_id\": agent_ids[cat],\n            \"agent_name\": SME_DISPLAY_NAMES[cat],\n            \"category\": cat,\n            \"reason\": f\"No {cat} deviations in this request\",\n            \"done\": False,\n        }\n\n    # Emit agent_start only for dispatched SMEs\n    for cat in dispatched:\n        yield {\n            \"type\": \"agent_start\",\n            \"agent_id\": agent_ids[cat],\n            \"agent_name\": SME_DISPLAY_NAMES[cat],\n            \"category\": cat,\n            \"deviation_count\": (categories_with_counts or {}).get(cat, 0),\n            \"done\": False,\n        }\n\n    # Run dispatched SMEs in parallel threads with a shared event queue\n    sme_r",
