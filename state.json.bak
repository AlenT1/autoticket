      "enriched": {
        "bug_id": "88e99da96d9a74d0",
        "summary": "SSE chat streams can end without clean timeout termination and persisted partial assistant content",
        "description_md": "## Symptom\nA long-running chat tool call causes the SSE test to hit its 30 s timeout instead of observing a clean stream close with `event: done` and persisted partial assistant content.\n\n## Where\n- `apps/centralbackend/app/orchestrator/chat_router.py:344-404` — `event_stream()` collects streamed events, persists `final_content` in `finally`, and emits the SSE termination marker.\n- `apps/centralbackend/app/orchestrator/chat_router.py:358-383` — exception handling inside the stream loop emits an error event, while the `finally` block is responsible for saving the assistant message and ending the stream.\n\n## Code snippet\n```python\n    async def event_stream():\n        final_content = \"\"\n        insight_data = None\n        tool_calls_collected: list[dict] = []\n        try:\n            async for event in run_orchestrator_streaming(\n                query, session_id, history,\n                user_sub=user_sub, user_email=user_email,\n                fault_inject_skills=fault_inject_skills_request,\n            ):\n                yield f\"data: {json.dumps(event, default=str)}\\n\\n\"\n                if event.get(\"type\") == \"tool_call\":\n                    tool_calls_collected.append({\"tool\": event.get(\"tool\", \"\"), \"server\": event.get(\"server\", \"\")})\n                if event.get(\"type\") == \"tool_result\":\n                    for tc in tool_calls_collected:\n                        if tc[\"tool\"] == event.get(\"tool\") and tc[\"server\"] == event.get(\"server\"):\n                            tc[\"duration_ms\"] = event.get(\"duration_ms\", 0)\n                            tc[\"status\"] = \"done\"\n                            if event.get(\"tool_trace_id\"):\n                                tc[\"tool_trace_id\"] = event[\"tool_trace_id\"]\n                if event.get(\"type\") == \"done\":\n                    final_content = event.get(\"content\", \"\")\n                    insight_data = event.get(\"insight_data\")\n        except Exception as e:\n            stream_trace = str(uuid.uuid4())\n            logger.error(\n                \"Chat stream error (trace_id=%s): %s\", stream_trace, e, exc_info=True,\n            )\n            user_msg = _safe_error_message(e, \"We hit an unexpected issue while answering. Please try again.\")\n            yield (\n                \"data: \"\n                + json.dumps({\n                    \"type\": \"error\",\n                    \"error_code\": \"chat_stream_failed\",\n                    \"user_message\": user_msg,\n                    \"message\": user_msg,\n                    \"trace_id\": stream_trace,\n                })\n                + \"\\n\\n\"\n            )\n        finally:\n            if final_content:\n                append_message(session_id, \"assistant\", final_content)\n                await history_db.save_message(\n                    session_id, \"assistant\", final_content,\n                    insight_data=insight_data,\n                    tool_calls=tool_calls_collected if tool_calls_collected else None,\n                )\n\n            if is_new_session and final_content:\n                title = await _generate_title(query, user_email=user_email, session_id=session_id)\n                await history_db.update_session_title(session_id, title)\n                yield f\"data: {json.dumps({'type': 'session_title', 'session_id': session_id, 'title': title})}\\n\\n\"\n\n            # Canonical SSE termination marker. Smoke clients (X-SMOKE-002 /\n            # 003) read until this sentinel; without it the stream looks\n            # half-open and they fail with \"never saw [DONE]\" even though the\n            # orchestrator finished cleanly.\n            yield \"data: [DONE]\\n\\n\"\n```\n\n## Reproduction steps\n1. Start the chat SSE endpoint with a prompt that triggers a long-running tool call.\n2. Keep the stream open until the tool work completes or times out.\n3. Observe whether the client receives a terminal SSE marker and whether the assistant reply is persisted before disconnect.\n4. Run the affected test case; it stalls until the 30 s timeout instead of completing cleanly.\n\n## Expected behavior\nThe stream ends with the terminal SSE marker, and any partial assistant content produced before termination is saved to chat history.\n\n## Actual behavior\nThe test does not complete within 30 s, indicating the SSE connection does not close in the expected clean way for this long-running tool-call path.\n\n## Last toucher\navivriftin5 on 2026-05-03\n\n## Related\n- `CORE-CHAT-026` is referenced in the bug body as a similar failure mode.\n- Nearby logic in `apps/centralbackend/app/orchestrator/chat_router.py` handles streamed tool calls, final assistant content persistence, and SSE termination.\n",
        "reproduction_steps": [
          {
            "order": 1,
            "text": "Open the chat SSE endpoint with a prompt that triggers a long-running tool call."
          },
          {
            "order": 2,
            "text": "Wait for the tool execution to run long enough to exercise the timeout-sensitive path."
          },
          {
            "order": 3,
            "text": "Observe whether the stream terminates with the SSE end marker and whether the assistant content is saved before disconnect."
          },
          {
            "order": 4,
            "text": "Run the affected test and observe that it reaches the 30 s timeout instead of finishing cleanly."
          }
        ],
        "expected_behavior": "The SSE chat stream completes cleanly for long-running tool calls, emits the terminal marker, and persists the assistant content produced before termination.",
        "actual_behavior": "The long-running tool-call path leaves the test waiting until its 30 s timeout instead of observing a clean stream close with persisted partial assistant content.",
        "code_references": [
          {
            "repo_alias": "_core",
            "repo_url": null,
            "file_path": "apps/centralbackend/app/orchestrator/chat_router.py",
            "line_start": 344,
            "line_end": 404,
            "commit_sha": null,
            "snippet": "    async def event_stream():\n        final_content = \"\"\n        insight_data = None\n        tool_calls_collected: list[dict] = []\n        try:\n            async for event in run_orchestrator_streaming(\n                query, session_id, history,\n                user_sub=user_sub, user_email=user_email,\n                fault_inject_skills=fault_inject_skills_request,\n            ):\n                yield f\"data: {json.dumps(event, default=str)}\\n\\n\"\n                if event.get(\"type\") == \"tool_call\":\n                    tool_calls_collected.append({\"tool\": event.get(\"tool\", \"\"), \"server\": event.get(\"server\", \"\")})\n                if event.get(\"type\") == \"tool_result\":\n                    for tc in tool_calls_collected:\n                        if tc[\"tool\"] == event.get(\"tool\") and tc[\"server\"] == event.get(\"server\"):\n                            tc[\"duration_ms\"] = event.get(\"duration_ms\", 0)\n                            tc[\"status\"] = \"done\"\n                            if event.get(\"tool_trace_id\"):\n                                tc[\"tool_trace_id\"] = event[\"tool_trace_id\"]\n                if event.get(\"type\") == \"done\":\n                    final_content = event.get(\"content\", \"\")\n                    insight_data = event.get(\"insight_data\")\n        except Exception as e:\n            stream_trace = str(uuid.uuid4())\n            logger.error(\n                \"Chat stream error (trace_id=%s): %s\", stream_trace, e, exc_info=True,\n            )\n            user_msg = _safe_error_message(e, \"We hit an unexpected issue while answering. Please try again.\")\n            yield (\n                \"data: \"\n                + json.dumps({\n                    \"type\": \"error\",\n                    \"error_code\": \"chat_stream_failed\",\n                    \"user_message\": user_msg,\n                    \"message\": user_msg,\n                    \"trace_id\": stream_trace,\n                })\n                + \"\\n\\n\"\n            )\n        finally:\n            if final_content:\n                append_message(session_id, \"assistant\", final_content)\n                await history_db.save_message(\n                    session_id, \"assistant\", final_content,\n                    insight_data=insight_data,\n                    tool_calls=tool_calls_collected if tool_calls_collected else None,\n                )\n\n            if is_new_session and final_content:\n                title = await _generate_title(query, user_email=user_email, session_id=session_id)\n                await history_db.update_session_title(session_id, title)\n                yield f\"data: {json.dumps({'type': 'session_title', 'session_id': session_id, 'title': title})}\\n\\n\"\n\n            # Canonical SSE termination marker. Smoke clients (X-SMOKE-002 /\n            # 003) read until this sentinel; without it the stream looks\n            # half-open and they fail with \"never saw [DONE]\" even though the\n            # orchestrator finished cleanly.\n            yield \"data: [DONE]\\n\\n\"",
            "blame_author": null,
            "blame_date": null
          }
