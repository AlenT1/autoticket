# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored — never commit it.
#
# This is the ONLY file an operator edits. All non-secret defaults
# (model names, matcher tunables, repo aliases, etc.) live in the
# shipped YAMLs under `configs/`. You should not edit those.
#
# Each variable below has exactly ONE canonical name. Legacy alternatives
# (NVIDIA_LLM_API_KEY, JIRA_PAT, FOLDER_ID, etc.) are silently ignored.
#
# Two tools share this file:
#   - f2j (file_to_jira)         markdown bug-list -> Jira Bug tickets
#   - jira-task-agent            Drive doc folder  -> Jira Epics + Tasks

# =============================================================================
# Jira (used by both tools)
# =============================================================================
JIRA_HOST=                          # e.g. jirasw.nvidia.com or yourorg.atlassian.net
JIRA_PROJECT_KEY=                   # e.g. CENTPM
JIRA_AUTH_MODE=bearer               # "bearer" (Server/DC) | "basic" (Cloud)
JIRA_USER_EMAIL=                    # required only when JIRA_AUTH_MODE=basic
JIRA_TOKEN=                         # PAT (Server/DC) or API token (Cloud)
JIRA_CA_BUNDLE=                     # optional, custom CA cert path

# autodev convention. If JIRA_TOKEN above is empty, the agent looks for a
# token at ~/.autodev/tokens/task-jira-${JIRA_PROJECT_KEY}, then falls back
# to AUTODEV_TOKEN below.
AUTODEV_TOKEN=

# =============================================================================
# LLM — NVIDIA Inference (OpenAI-compatible)
# =============================================================================
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://inference-api.nvidia.com/v1/

# =============================================================================
# LLM — Anthropic (used only when f2j.enrichment.provider = "anthropic")
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=                 # optional proxy

# =============================================================================
# Google Drive — used by jira_task_agent and by f2j --source gdrive
# =============================================================================
DRIVE_FOLDER_ID=                    # Drive folder UUID
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# =============================================================================
# GitLab — only if any f2j repo_alias in configs/f2j.yaml uses auth: https-token
# =============================================================================
GITLAB_TOKEN=
