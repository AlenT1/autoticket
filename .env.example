# --- Google Drive ---
FOLDER_ID=

# --- Jira ---
JIRA_HOST=                  # e.g. jira.nvidia.com  OR  yourorg.atlassian.net
JIRA_PROJECT_KEY=           # e.g. CENT

# Auth mode:
#   bearer  -> Personal Access Token (Jira Server / Data Center)  [default]
#   basic   -> email + API token base64-encoded (Jira Cloud)
JIRA_AUTH_MODE=bearer
JIRA_USER_EMAIL=            # required only when JIRA_AUTH_MODE=basic

# Token (any one of these — first hit wins):
#   1. JIRA_TOKEN env (this file)
#   2. ~/.autodev/tokens/task-jira-${JIRA_PROJECT_KEY}
#   3. AUTODEV_TOKEN env
# JIRA_TOKEN=

# --- LLM (NVIDIA Inference; OpenAI-compatible) ---
# Defaults match the central codebase (see CentArb's llm/client.py).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://inference-api.nvidia.com/v1/
# Model overrides (optional). Leave blank to use the in-code defaults.
LLM_MODEL_CLASSIFY=meta/llama-3.1-70b-instruct
LLM_MODEL_EXTRACT=openai/openai/gpt-5.2
LLM_MODEL_SUMMARIZE=meta/llama-3.1-8b-instruct

# --- Local-folder source (optional) ---
# Display name stamped as "Last edited by:" in descriptions extracted
# from data/local_files/. Defaults to $USER if unset.
LOCAL_AUTHOR_NAME=Saar Riftin
