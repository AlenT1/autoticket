# Copy this file to `.env` and fill in. `.env` is gitignored.
# Only secrets live here; structured config goes in `f2j.yaml` (f2j) or
# environment-driven flags (jira_task_agent).
#
# Two tools live in this repo, sharing this single .env:
#   - f2j (file_to_jira)         markdown bug-list -> Jira Bug tickets
#   - jira-task-agent            Drive doc folder  -> Jira Epics + Tasks
# Most keys are common; tool-specific keys are flagged.

# =============================================================================
# Jira (shared by both tools)
# =============================================================================
JIRA_HOST=                  # e.g. jirasw.nvidia.com  OR  yourorg.atlassian.net
JIRA_PROJECT_KEY=           # e.g. CENTPM

# Auth mode:
#   bearer  -> Personal Access Token (Jira Server / Data Center)  [default]
#   basic   -> email + API token base64-encoded (Jira Cloud)
JIRA_AUTH_MODE=bearer
JIRA_USER_EMAIL=            # required only when JIRA_AUTH_MODE=basic

# Token resolution chain (first hit wins):
#   1. JIRA_TOKEN env (this file)
#   2. JIRA_PAT env (f2j legacy alias; same effect as JIRA_TOKEN)
#   3. ~/.autodev/tokens/task-jira-${JIRA_PROJECT_KEY}
#   4. AUTODEV_TOKEN env
# JIRA_TOKEN=
# JIRA_PAT=

# =============================================================================
# LLM (shared — NVIDIA Inference, OpenAI-compatible)
# =============================================================================
# jira_task_agent reads NVIDIA_API_KEY; f2j reads NVIDIA_LLM_API_KEY when its
# enrichment.provider is openai_compatible. Set both to the same value.
NVIDIA_API_KEY=
NVIDIA_LLM_API_KEY=
NVIDIA_BASE_URL=https://inference-api.nvidia.com/v1/

# jira_task_agent: model overrides (optional). Leave blank to use in-code defaults.
LLM_MODEL_CLASSIFY=meta/llama-3.1-70b-instruct
LLM_MODEL_EXTRACT=openai/openai/gpt-5.2
LLM_MODEL_SUMMARIZE=meta/llama-3.1-8b-instruct

# f2j: optional Anthropic path (currently dormant — operational use is via
# the OpenAI-compat NVIDIA endpoint above; kept as a second LLMProvider impl).
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_AUTH_TOKEN=

# =============================================================================
# jira_task_agent — input source
# =============================================================================
FOLDER_ID=                  # Google Drive folder UUID (when --source includes gdrive)

# Display name stamped as "Last edited by:" in descriptions extracted from
# data/local_files/. Defaults to $USER if unset.
LOCAL_AUTHOR_NAME=

# =============================================================================
# f2j — repo cloning for source-code browsing
# =============================================================================
# GitLab PAT — needed if a repo_alias in f2j.yaml uses auth: https-token.
# NVIDIA: generate at
#   https://gitlab-master.nvidia.com/-/user_settings/personal_access_tokens
# Scopes: api, read_repository
GIT_TOKEN_GITLAB_NVIDIA=

# GitHub token — only if a repo_alias points at github.com via https-token.
GIT_TOKEN_GITHUB=
