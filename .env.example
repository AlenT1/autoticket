# Copy this file to `.env` and fill in. `.env` is gitignored.
# Only secrets live here; structured config goes in f2j.yaml.

# --- Enrichment provider ----------------------------------------------------
# Pick ONE of the two paths below. Provider selection itself lives in
# f2j.yaml (`enrichment.provider`), not here — only the secrets are in env.

# Path A: Anthropic API (default if `enrichment.provider: anthropic` in f2j.yaml).
ANTHROPIC_API_KEY=

# Path B: OpenAI-compatible endpoint such as NVIDIA Inference Hub.
# Set this when `enrichment.provider: openai_compatible` is in f2j.yaml.
# The env-var NAME (NVIDIA_LLM_API_KEY by default) is configurable in
# `f2j.yaml` under `openai_compatible.api_key_env`.
NVIDIA_LLM_API_KEY=

# Optional: route Anthropic SDK through an internal proxy (rarely used now
# that openai_compatible is available). NVIDIA MaaS, AWS Bedrock shim, etc.
# ANTHROPIC_BASE_URL=https://maas.prd.astra.nvidia.com/...
# ANTHROPIC_AUTH_TOKEN=

# Jira Data Center Personal Access Token — required for upload.
# NVIDIA: generate at
#   https://jirasw.nvidia.com/plugins/servlet/de.resolution.apitokenauth/admin
# Same token used by `jira` CLI (ankitpokhrel/jira-cli) — copy it from there.
JIRA_PAT=

# GitLab token — only needed if a repo_alias uses auth: https-token
# NVIDIA: generate at
#   https://gitlab-master.nvidia.com/-/user_settings/personal_access_tokens
# Scopes: api, read_repository
# If using auth: glab instead, this is unnecessary — `glab` reads its own config.
GIT_TOKEN_GITLAB_NVIDIA=

# GitHub token — only needed if a repo_alias points at github.com with https-token.
GIT_TOKEN_GITHUB=
